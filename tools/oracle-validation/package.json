{
  "name": "oracle-validation",
  "private": true,
  "type": "module",
  "scripts": {
    "oracle:data": "tsx src/runner.ts --suite data",
    "oracle:stats": "tsx src/runner.ts --suite stats",
    "oracle:groundtruth": "tsx src/runner.ts --suite groundTruth",
    "oracle:fast": "tsx src/runner.ts --suite fast",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@pkmn/data": "0.10.7",
    "@pkmn/dex": "0.10.7",
    "@pkmn/sim": "0.10.7",
    "@smogon/calc": "0.11.0",
    "zod": "4.3.6",
    "@pokemon-lib-ts/battle": "*",
    "@pokemon-lib-ts/core": "*",
    "@pokemon-lib-ts/gen1": "*",
    "@pokemon-lib-ts/gen2": "*",
    "@pokemon-lib-ts/gen3": "*",
    "@pokemon-lib-ts/gen4": "*",
    "@pokemon-lib-ts/gen5": "*",
    "@pokemon-lib-ts/gen6": "*",
    "@pokemon-lib-ts/gen7": "*",
    "@pokemon-lib-ts/gen8": "*",
    "@pokemon-lib-ts/gen9": "*"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  }
}

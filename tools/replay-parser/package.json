{
  "name": "replay-parser",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests --passWithNoTests",
    "test:integration": "vitest run \"tests/integration/**/*.test.ts\" --passWithNoTests",
    "test:smoke": "vitest run \"tests/smoke/**/*.test.ts\" --passWithNoTests",
    "test:e2e": "vitest run \"tests/e2e/**/*.test.ts\" --passWithNoTests",
    "test:stress": "vitest run \"tests/stress/**/*.test.ts\" --passWithNoTests",
    "test:all": "npm run test && npm run test:smoke && npm run test:e2e && npm run test:stress",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pokemon-lib-ts/battle": "*",
    "@pokemon-lib-ts/core": "*",
    "@pokemon-lib-ts/gen1": "*",
    "@pokemon-lib-ts/gen2": "*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  }
}

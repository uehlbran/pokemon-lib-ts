{
  "name": "pokemon-lib-ts",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "ci:package-boundaries": "tsx scripts/verify-package-boundaries.ts",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:invariants": "npm run test:invariants --workspace @pokemon-lib-ts/core && npm run test:invariants --workspace @pokemon-lib-ts/battle && npm run test:invariants --workspace data-importer",
    "test:smoke": "turbo run test:smoke",
    "test:e2e": "turbo run test:e2e",
    "test:stress": "turbo run test:stress",
    "test:all": "turbo run test:all",
    "test:slow": "npm run test:smoke",
    "test:workflow": "node --test scripts/tests/*.test.mjs",
    "typecheck": "turbo run typecheck",
    "typecheck:contracts": "npm run typecheck:contracts --workspace @pokemon-lib-ts/battle",
    "lint": "npx @biomejs/biome check --write .",
    "lint:check": "npx @biomejs/biome check .",
    "generate:reference-ids": "tsx scripts/generate-reference-ids.ts",
    "verify:local": "node scripts/verify-local.mjs",
    "changeset:check": "node scripts/check-changeset.mjs",
    "pr:check": "node scripts/check-pr-body.mjs",
    "review:check": "node scripts/check-review-marker.mjs",
    "pr:open": "node scripts/create-pr.mjs",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "replay:download": "tsx tools/replay-parser/src/index.ts download --format gen1ou --count 30",
    "replay:validate": "tsx tools/replay-parser/src/index.ts validate-all tools/replay-parser/replays/gen1/",
    "replay:simulate:gen1": "tsx tools/replay-parser/src/index.ts simulate --gen 1 --battles 250",
    "replay:simulate:gen2": "tsx tools/replay-parser/src/index.ts simulate --gen 2 --battles 100",
    "replay:report": "tsx tools/replay-parser/src/index.ts validate-all tools/replay-parser/replays/gen1/ --json",
    "oracle:data": "tsx tools/oracle-validation/src/runner.ts --suite data",
    "oracle:damage": "tsx tools/oracle-validation/src/runner.ts --suite damage",
    "oracle:mechanics": "tsx tools/oracle-validation/src/runner.ts --suite mechanics",
    "oracle:terrain": "tsx tools/oracle-validation/src/runner.ts --suite terrain",
    "oracle:gimmicks": "tsx tools/oracle-validation/src/runner.ts --suite gimmicks",
    "oracle:replay": "tsx tools/oracle-validation/src/runner.ts --suite replay",
    "oracle:trace": "tsx tools/oracle-validation/src/runner.ts --suite damageTrace",
    "oracle:stats": "tsx tools/oracle-validation/src/runner.ts --suite stats",
    "oracle:groundtruth": "tsx tools/oracle-validation/src/runner.ts --suite groundTruth",
    "oracle:fast": "tsx tools/oracle-validation/src/runner.ts --suite fast",
    "proof:preview": "tsx tools/oracle-validation/src/changed-mechanics.ts",
    "proof:enforce": "tsx tools/oracle-validation/src/enforce-impacts.ts",
    "proof:audit:mutation": "tsx tools/oracle-validation/src/direct-mutation-audit.ts",
    "smoke": "tsx tools/oracle-validation/src/runner.ts --suite smoke",
    "compliance": "tsx tools/oracle-validation/src/runner.ts --suite all",
    "test:oracle": "npm run test --workspace oracle-validation",
    "validate:pret": "tsx tools/data-importer/src/pret-overrides/validate-committed-data.ts",
    "test:mutant": "stryker run stryker.config.mjs",
    "test:mutant:core": "stryker run stryker.config.mjs",
    "test:mutant:gen1": "stryker run stryker.gen1.config.mjs",
    "test:mutant:gen2": "stryker run stryker.gen2.config.mjs",
    "test:mutant:gen3": "stryker run stryker.gen3.config.mjs",
    "test:mutant:gen4": "stryker run stryker.gen4.config.mjs",
    "test:mutant:gen5": "stryker run stryker.gen5.config.mjs",
    "test:mutant:gen6": "stryker run stryker.gen6.config.mjs",
    "test:mutant:gen7": "stryker run stryker.gen7.config.mjs",
    "test:mutant:gen8": "stryker run stryker.gen8.config.mjs",
    "test:mutant:gen9": "stryker run stryker.gen9.config.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.30.0",
    "@stryker-mutator/core": "^9.0.0",
    "@stryker-mutator/typescript-checker": "^9.0.0",
    "@stryker-mutator/vitest-runner": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}

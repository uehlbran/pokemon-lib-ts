{
  "name": "@pokemon-lib-ts/gen4",
  "version": "0.1.0",
  "description": "Gen 4 (Diamond/Pearl/Platinum) ruleset and data for pokemon-lib-ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/*.test.ts",
    "test:integration": "node ../../scripts/run-package-tier-tests.mjs integration",
    "test:smoke": "node ../../scripts/run-package-tier-tests.mjs smoke",
    "test:e2e": "node ../../scripts/run-package-tier-tests.mjs e2e",
    "test:stress": "node ../../scripts/run-package-tier-tests.mjs stress",
    "test:all": "npm run test && npm run test:smoke && npm run test:e2e && npm run test:stress",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pokemon-lib-ts/core": "*",
    "@pokemon-lib-ts/battle": "*"
  }
}

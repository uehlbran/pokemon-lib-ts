{
  "name": "@pokemon-lib-ts/gen8",
  "version": "0.0.1",
  "description": "Gen 8 (Sword/Shield) battle ruleset and data for pokemon-lib-ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data/*.json": "./data/*.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pokemon-lib-ts/core": "*",
    "@pokemon-lib-ts/battle": "*"
  }
}

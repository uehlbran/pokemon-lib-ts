{
  "name": "@pokemon-lib-ts/gen8",
  "version": "0.0.1",
  "description": "Gen 8 (Sword/Shield) battle ruleset and data for pokemon-lib-ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data/*.json": "./data/*.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/*.test.ts",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:smoke": "vitest run tests/smoke --passWithNoTests",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "test:stress": "vitest run tests/stress --passWithNoTests",
    "test:all": "npm run test && npm run test:smoke && npm run test:e2e && npm run test:stress",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pokemon-lib-ts/core": "*",
    "@pokemon-lib-ts/battle": "*"
  }
}

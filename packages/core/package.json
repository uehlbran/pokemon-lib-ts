{
  "name": "@pokemon-lib-ts/core",
  "version": "0.8.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ../../scripts/run-package-tier-tests.mjs unit",
    "test:integration": "node ../../scripts/run-package-tier-tests.mjs integration",
    "test:smoke": "node ../../scripts/run-package-tier-tests.mjs smoke",
    "test:e2e": "node ../../scripts/run-package-tier-tests.mjs e2e",
    "test:stress": "node ../../scripts/run-package-tier-tests.mjs stress",
    "test:all": "npm run test && npm run test:smoke && npm run test:e2e && npm run test:stress",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}

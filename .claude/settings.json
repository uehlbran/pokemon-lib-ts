{
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-review-gate.sh"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-changeset-gate.sh"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-comment-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/cleanup-review-marker.sh"
          }
        ]
      }
    ]
  }
}
